<Window x:Class="Test.ShopBilling.WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test.ShopBilling.WPFApp"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">

    <StackPanel Margin="20">

        <!-- Product Name -->

        <TextBlock Text="Product Name"/>

        <TextBox Width="200"
                 Margin="0,5,0,10"
                 Text="{Binding ProductName,
                                UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Product Price -->

        <TextBlock Text="Product Price"/>

        <TextBox Width="200"
                 Margin="0,5,0,10"
                 Text="{Binding ProductPrice,
                                UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Button -->

        <Button Content="Add Product"
                Width="150"
                Height="40"
                Margin="0,10,0,10"
                Click="Button_Click"/>

        <!-- Products Table -->

        <DataGrid Margin="0,10,0,0"
                  ItemsSource="{Binding Products}"
                  AutoGenerateColumns="False"
                  Height="200">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding ProductName}"/>

                <DataGridTextColumn Header="Price"
                                    Binding="{Binding ProductPrice}"/>

                <DataGridTextColumn Header="Quantity"
                                    Binding="{Binding ProductQuantity}"/>

                <DataGridTemplateColumn Header="Actions">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </StackPanel>

</Window>